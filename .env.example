NEW_ERA_ENV=local
NEW_ERA_HOST=127.0.0.1
NEW_ERA_PORT=8000
NEW_ERA_RUNTIME_DIR=.new_era
NEW_ERA_SQLITE_PATH=.new_era/runtime.sqlite3
NEW_ERA_DATABASE_URL=sqlite:///.new_era/runtime.sqlite3
NEW_ERA_LOCAL_USER_ID=local-demo-user
NEW_ERA_LOCAL_AUTH_USER_ID=local-demo-user
NEW_ERA_LOCAL_AUTH_PASSWORD=local-demo-password
NEW_ERA_ENABLE_DEV_AUTH=0
